# WipSom Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Database (Neon PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/wipsom?sslmode=require

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Email (choose one) ─────────────────────────────────────────
# Option A: Brevo (Sendinblue) — free 300 emails/day
BREVO_LOGIN=your@email.com
BREVO_SMTP_KEY=your_brevo_smtp_key

# Option B: Generic SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

EMAIL_FROM=WipSom <no-reply@wipsom.com>

# ── Razorpay ───────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret   # optional but recommended

# ── Shiprocket (optional) ──────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password
WAREHOUSE_PIN=110001   # your warehouse pincode

# ── Google Sheets (optional — order logging) ───────────────────
# GOOGLE_SHEET_ID=your_sheet_id
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
