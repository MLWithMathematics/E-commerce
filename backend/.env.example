# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shopverse
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=https:/e-commerce-ashen-omega.vercel.app

# ── Uploads ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Email (for account verification) ─────────────────────────
# Option A: Gmail — use an App Password (not your real password)
#   Go to Google Account → Security → 2-Step → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Option B: Outlook / Hotmail
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password

# Option C: Mailtrap (free sandbox for testing — https://mailtrap.io)
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=<mailtrap-user>
# SMTP_PASS=<mailtrap-pass>

# Sender name shown in emails
EMAIL_FROM=WipSom <no-reply@wipsom.com>

# ── Dev mode ─────────────────────────────────────────────────
# If SMTP is not configured, verification link is printed to console.
# Set to "true" to skip email sending entirely and auto-log the link.
DEV_SKIP_EMAIL=true
