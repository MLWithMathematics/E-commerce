# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shopverse
DB_USER=postgres
DB_PASSWORD=yourpassword
DATABASE_URL=your_DATABASE_URL

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=your_client_url

# ── Uploads ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Email (for account verification) ─────────────────────────
# Option A: Gmail — use an App Password (not your real password)
#   Go to Google Account → Security → 2-Step → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Option B: Outlook / Hotmail
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password

# Option C: Mailtrap (free sandbox for testing — https://mailtrap.io)
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=<mailtrap-user>
# SMTP_PASS=<mailtrap-pass>

# Sender name shown in emails
EMAIL_FROM=WipSom <no-reply@wipsom.com>

# ── Dev mode ─────────────────────────────────────────────────
# If SMTP is not configured, verification link is printed to console.
# Set to "true" to skip email sending entirely and auto-log the link.
DEV_SKIP_EMAIL=true

# ── Brevo (free email — 300/day) ───────────────────────────────────
# Sign up at https://app.brevo.com → SMTP & API → SMTP Keys
# When BREVO_SMTP_KEY is present it takes priority over SMTP_* above.
BREVO_LOGIN=you@example.com
BREVO_SMTP_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets order sync (free) ───────────────────────────
# 1. Create a Google Cloud project, enable Sheets API, create a Service Account.
# 2. Download the JSON key. Share your target Sheet with the service account email.
# 3. npm install googleapis  (in backend/)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── Shiprocket (delivery estimates) ────────────────────────────
# Sign up free at https://app.shiprocket.in
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=yourpassword
WAREHOUSE_PIN=110001

# ── WhatsApp / Crisp / Clarity ─────────────────────────────────
# These are client-side only — configure directly in frontend files:
#   WhatsApp:  frontend/src/App.jsx  → WA_NUMBER
#   Crisp:     frontend/index.html  → CRISP_WEBSITE_ID
#   Clarity:   frontend/index.html  → YOUR_CLARITY_PROJECT_ID
