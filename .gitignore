# Dependencies — never commit these
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment files — set these in Railway/Vercel dashboards
frontend/.env
.env.local
.env.production

# Frontend build output — Vercel builds this automatically
frontend/dist/

# Logs
*.log
npm-debug.log*

# Uploads (user-uploaded files, not code)
backend/uploads/*
!backend/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db
graphify-out
Summary-Claude
.agent
.Claude
.graphifyignore
CLAUDE.md 
Summary-Claude.txt
